{
  "id": "demo_agent_flaky_tool_retry",
  "name": "Demo Agent Flaky Tool Retry",
  "description": "Checks that the generic demo agent retries a flaky tool — first attempt fails, second attempt succeeds.",
  "module_id": "demo_agent",
  "input": "hello eval __flaky_tool__",
  "expected_status": "completed",
  "expected_output_contains": ["demo_agent mock response"],
  "expected_events": ["run.created", "run.started", "tool.call.started", "tool.call.retry_scheduled", "tool.call.completed", "run.completed"],
  "expected_steps": ["input_node", "skill_node", "tool_node", "final_node"],
  "expected_checkpoints_min": 4,
  "expected_trace_spans_min": 4,
  "expected_timeline_items_min": 4,
  "expected_tool_calls_min": 1,
  "metadata": {
    "path": "flaky"
  }
}
