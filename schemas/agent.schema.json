{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent",
  "description": "Minimal contract for an agent definition inside a module.",
  "type": "object",
  "required": [
    "id",
    "module_id",
    "name",
    "description",
    "system_prompt_path",
    "skills",
    "tools",
    "workflow",
    "provider"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique agent identifier."
    },
    "module_id": {
      "type": "string",
      "description": "Module identifier that owns this agent."
    },
    "name": {
      "type": "string",
      "description": "Human-readable agent name."
    },
    "description": {
      "type": "string",
      "description": "Agent purpose and boundary."
    },
    "version": {
      "type": "string",
      "description": "Agent version."
    },
    "system_prompt_path": {
      "type": "string",
      "description": "Path to the agent system prompt inside the module."
    },
    "skills": {
      "type": "array",
      "description": "Skill ids requested by this agent.",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "description": "Tool ids requested by this agent.",
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "string",
      "description": "Workflow mode used by this agent."
    },
    "provider": {
      "type": "string",
      "description": "Default provider id for this agent."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Agent creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last agent update timestamp."
    }
  },
  "additionalProperties": false
}
