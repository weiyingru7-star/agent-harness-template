{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Embedding",
  "description": "Contract for embedding provider result.",
  "type": "object",
  "required": ["embeddings", "model", "dimensions"],
  "properties": {
    "embeddings": {
      "type": "array",
      "description": "List of embedding vectors.",
      "items": {
        "type": "array",
        "items": { "type": "number" }
      }
    },
    "model": {
      "type": "string",
      "description": "Provider model name."
    },
    "dimensions": {
      "type": "integer",
      "description": "Embedding vector dimensions."
    },
    "usage": {
      "type": "object",
      "description": "Token usage or other resource counts."
    },
    "metadata": {
      "type": "object",
      "description": "Optional embedding metadata."
    }
  },
  "additionalProperties": false
}
