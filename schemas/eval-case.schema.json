{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eval Case",
  "description": "Minimal contract for a single trajectory evaluation case.",
  "type": "object",
  "required": [
    "id",
    "name",
    "module_id",
    "input",
    "expected_status",
    "expected_output_contains",
    "expected_events",
    "expected_steps",
    "expected_checkpoints_min",
    "expected_trace_spans_min",
    "expected_timeline_items_min",
    "expected_tool_calls_min",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique evaluation case identifier."
    },
    "name": {
      "type": "string",
      "description": "Human-readable evaluation case name."
    },
    "description": {
      "type": "string",
      "description": "Evaluation case purpose and boundary."
    },
    "module_id": {
      "type": "string",
      "description": "Module identifier to execute."
    },
    "input": {
      "type": "string",
      "description": "Evaluation input."
    },
    "expected_status": {
      "type": "string",
      "description": "Expected final run status.",
      "enum": ["completed", "failed"]
    },
    "expected_output_contains": {
      "type": "array",
      "description": "Strings expected to appear in the final output. Use an empty list when output is not expected.",
      "items": {
        "type": "string"
      }
    },
    "expected_events": {
      "type": "array",
      "description": "Event types expected in the run trajectory.",
      "items": {
        "type": "string"
      }
    },
    "expected_steps": {
      "type": "array",
      "description": "Step names expected in the run trajectory.",
      "items": {
        "type": "string"
      }
    },
    "expected_checkpoints_min": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum number of checkpoints expected."
    },
    "expected_trace_spans_min": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum number of trace spans expected."
    },
    "expected_timeline_items_min": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum number of timeline items expected."
    },
    "expected_tool_calls_min": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum number of tool calls expected."
    },
    "metadata": {
      "type": "object",
      "description": "Optional generic metadata."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Evaluation case creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last evaluation case update timestamp."
    }
  },
  "additionalProperties": false
}
