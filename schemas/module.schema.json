{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Module",
  "description": "Minimal contract for a module definition.",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description",
    "entrypoint",
    "enabled",
    "capabilities",
    "default_agent"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique module identifier."
    },
    "name": {
      "type": "string",
      "description": "Human-readable module name."
    },
    "description": {
      "type": "string",
      "description": "Module purpose and boundary."
    },
    "version": {
      "type": "string",
      "description": "Module version."
    },
    "entrypoint": {
      "type": "string",
      "description": "Python entrypoint using module.path:function format."
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether this module can be discovered and selected."
    },
    "capabilities": {
      "type": "array",
      "description": "Generic capabilities exposed by the module.",
      "items": {
        "type": "string"
      }
    },
    "default_agent": {
      "type": "string",
      "description": "Default agent id for this module."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Module creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last module update timestamp."
    }
  },
  "additionalProperties": false
}
