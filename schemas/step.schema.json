{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Step",
  "description": "Minimal contract for a single step within a run.",
  "type": "object",
  "required": ["id", "run_id", "name", "status", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique step identifier."
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier that owns this step."
    },
    "name": {
      "type": "string",
      "description": "Step name."
    },
    "status": {
      "type": "string",
      "description": "Current step status."
    },
    "type": {
      "type": "string",
      "description": "Step type such as node, tool, llm, or final."
    },
    "trace_id": {
      "type": "string",
      "description": "Trace identifier associated with this step."
    },
    "span_id": {
      "type": "string",
      "description": "Span identifier associated with this step."
    },
    "parent_span_id": {
      "type": "string",
      "description": "Optional parent span identifier."
    },
    "input": {
      "type": "string",
      "description": "Step input text."
    },
    "output": {
      "type": "string",
      "description": "Step output text."
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Step start timestamp."
    },
    "ended_at": {
      "type": "string",
      "format": "date-time",
      "description": "Step end timestamp."
    },
    "duration_ms": {
      "type": "integer",
      "description": "Step duration in milliseconds."
    },
    "error": {
      "type": "string",
      "description": "Error message when the step fails."
    },
    "attempt": {
      "type": "integer",
      "description": "Step attempt number."
    },
    "max_attempts": {
      "type": "integer",
      "description": "Maximum attempts configured for this step."
    },
    "error_type": {
      "type": "string",
      "description": "Error type when the step fails."
    },
    "error_message": {
      "type": "string",
      "description": "Error message when the step fails."
    },
    "failed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Step failure timestamp."
    },
    "metadata": {
      "type": "object",
      "description": "Step metadata."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Step creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last step update timestamp."
    }
  },
  "additionalProperties": false
}
