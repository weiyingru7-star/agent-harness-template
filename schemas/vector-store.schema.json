{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VectorSearchResult",
  "description": "Contract for a single vector search result.",
  "type": "object",
  "required": ["id", "document_id", "chunk_id", "collection", "text", "score"],
  "properties": {
    "id": { "type": "string", "description": "Vector record identifier." },
    "document_id": { "type": "string", "description": "Associated document identifier." },
    "chunk_id": { "type": "string", "description": "Associated chunk identifier." },
    "collection": { "type": "string", "description": "Collection name." },
    "text": { "type": "string", "description": "Chunk text." },
    "score": { "type": "number", "description": "Similarity score." },
    "metadata": { "type": "object", "description": "Optional metadata." }
  },
  "additionalProperties": false
}
